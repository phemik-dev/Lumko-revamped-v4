{
  "name": "lumko-revamped-v4",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./app/globals.css -o ./public/lumko.css --minify",
    "predev": "npm run build:css",
    "dev": "node scripts/next-dev-direct.cjs",
    "prebuild": "npm run build:css",
    "build": "node scripts/next-runner.cjs build --experimental-build-mode compile",
    "build:full": "node scripts/next-runner.cjs build",
    "start": "node scripts/next-runner.cjs start",
    "typecheck": "tsc --noEmit --incremental false"
  },
  "dependencies": {
    "next": "^15.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
